{
    "builders": [
        {
            "communicator": "ssh",
            "source_path": "{{user `artifactory_download_url`}}/{{user `base_box_name`}}",
            "box_name": "{{user `box_name`}}",
            "template": "{{template_dir}}/vagrant-template.rb",
            "provider": "libvirt",
            "add_force": true,
            "skip_package": true,
            "teardown_method": "halt",
            "type": "vagrant",
            "name": "vagrant-org-base"
        }
    ],
    "provisioners": [
        {
            "only": [
                "vagrant-org-base"
            ],
            "environment_vars": [
                "HOME_DIR=/home/vagrant",
                "http_proxy={{user `http_proxy`}}",
                "https_proxy={{user `https_proxy`}}",
                "no_proxy={{user `no_proxy`}}",
                "ARTIFACTORY_URL={{user `artifactory_server`}}"
            ],
            "execute_command": "echo 'vagrant' | {{.Vars}} sudo -S -E sh -eux '{{.Path}}'",
            "expect_disconnect": true,
            "scripts": [
                "{{template_dir}}/org-base/scripts/{{user `box_os`}}.sh",
                "{{template_dir}}/_common/sudoers.sh",
                "{{template_dir}}/_common/fix_time.sh",
                "{{template_dir}}/_common/sshd.sh",
                "{{template_dir}}/_common/system.sh",
                "{{template_dir}}/_common/setup.sh"
            ],
            "type": "shell"
        }
    ],
    "post-processors": [
        {
            "name": "create-box",
            "type": "shell-local",
            "inline": [
                "sudo {{template_dir}}/_common/create_box.sh /var/lib/libvirt/images/output-vagrant-org-base_source.img box"
            ]
        },
        {
            "name": "Cleanup",
            "type": "shell-local",
            "inline": [
                "sudo virsh vol-list default | grep \"{{user `base_box_name`}}\" | awk '{print $2}' | xargs -I{} sudo virsh vol-delete {} || true",
                "sudo virsh vol-list default | grep \"output-vagrant-\" | awk '{print $2}' | xargs -I{} sudo virsh vol-delete {} || true"
            ]
        }
    ],
    "variables": {
        "base_box_name": "__OVERIDE_BY_USER__",
        "box_name": "{{user `name`}}-org-base"
    }
}