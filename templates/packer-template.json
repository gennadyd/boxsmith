{
    "builders": [
        {
            "name": "vagrant-org-base",
            "communicator": "ssh",
            "source_path": "{{user `source_path`}}",
            "box_name": "{{user `box_name`}}",
            "template": "{{template_dir}}/vagrant-template.rb",
            "provider": "libvirt",
            "add_force": true,
            "skip_package": true,
            "teardown_method": "halt",
            "type": "vagrant"
        },
        {
            "name": "vagrant-org-golden",
            "communicator": "ssh",
            "source_path": "{{user `source_path`}}",
            "box_name": "{{user `name`}}-org-base",
            "box_version": "{{user `base_box_version`}}",
            "template": "{{template_dir}}/vagrant-template.rb",
            "provider": "libvirt",
            "add_force": true,
            "skip_package": true,
            "teardown_method": "halt",
            "type": "vagrant"
        }
    ],
    "provisioners": [
        {
            "only": [
                "vagrant-org-base"
            ],
            "environment_vars": [
                "HOME_DIR=/home/vagrant",
                "http_proxy={{user `http_proxy`}}",
                "https_proxy={{user `https_proxy`}}",
                "no_proxy={{user `no_proxy`}}",
                "ARTIFACTORY_URL={{user `artifactory_server`}}",
                "DNS_SERVERS={{user `dns_servers`}}",
                "DNS_SEARCH_DOMAINS={{user `dns_search_domains`}}"
            ],
            "execute_command": "echo 'vagrant' | {{.Vars}} sudo -S -E sh -eux '{{.Path}}'",
            "expect_disconnect": true,
            "scripts": [
                "{{template_dir}}/org-base/scripts/{{user `box_os`}}.sh",
                "{{template_dir}}/_common/sudoers.sh",
                "{{template_dir}}/_common/fix_time.sh",
                "{{template_dir}}/_common/sshd.sh",
                "{{template_dir}}/_common/system.sh",
                "{{template_dir}}/_common/setup.sh"
            ],
            "type": "shell"
        },
        {
            "only": [
                "vagrant-org-base"
            ],
            "environment_vars": [
                "BOX_TYPE={{user `box_type`}}",
                "BOX_OS={{user `box_os`}}",
                "BOX_OS_VERSION={{user `box_os_version`}}",
                "BOX_VERSION={{user `box_version`}}"
            ],
            "execute_command": "echo 'vagrant' | {{.Vars}} sudo -S -E sh -eux '{{.Path}}'",
            "inline": [
                "cat > /etc/box-release <<EOF",
                "BOX_TYPE=${BOX_TYPE}",
                "BOX_OS=${BOX_OS}",
                "BOX_OS_VERSION=${BOX_OS_VERSION}",
                "BOX_VERSION=${BOX_VERSION}",
                "BOX_NAME=${BOX_OS}-${BOX_OS_VERSION}-${BOX_TYPE}-${BOX_VERSION}",
                "EOF",
                "chmod 0644 /etc/box-release"
            ],
            "type": "shell"
        },
        {
            "only": [
                "vagrant-org-golden"
            ],
            "type": "ansible",
            "user": "vagrant",
            "playbook_file": "{{template_dir}}/ansible/playbooks/org-golden.yml",
            "ansible_env_vars": [
                "ANSIBLE_CONFIG={{template_dir}}/ansible/ansible.cfg",
                "ANSIBLE_ROLES_PATH={{template_dir}}/ansible/roles:{{template_dir}}/ansible/playbooks/roles"
            ],
            "extra_arguments": [
                "-vv",
                "--extra-vars",
                "ansible_python_interpreter=auto box_type={{user `box_type`}} box_os={{user `box_os`}} box_os_version={{user `box_os_version`}} box_version={{user `box_version`}}"
            ]
        },
        {
            "only": [
                "vagrant-org-golden"
            ],
            "environment_vars": [
                "HOME_DIR=/home/vagrant",
                "http_proxy={{user `http_proxy`}}",
                "https_proxy={{user `https_proxy`}}",
                "no_proxy={{user `no_proxy`}}"
            ],
            "execute_command": "echo 'vagrant' | {{.Vars}} sudo -S -E sh -eux '{{.Path}}'",
            "expect_disconnect": true,
            "scripts": [
                "{{template_dir}}/org-golden/scripts/cleanup-{{user `box_os`}}.sh"
            ],
            "type": "shell"
        }
    ],
    "post-processors": [
        {
            "name": "create-box",
            "type": "shell-local",
            "inline": [
                "sudo {{template_dir}}/_common/create_box.sh /var/lib/libvirt/images/output-vagrant-{{user `box_type`}}_source.img box"
            ]
        },
        {
            "name": "Cleanup",
            "type": "shell-local",
            "inline": [
                "sudo virsh vol-list default | grep \"{{user `name`}}\" | awk '{print $2}' | xargs -I{} sudo virsh vol-delete {} || true",
                "sudo virsh vol-list default | grep \"output-vagrant-\" | awk '{print $2}' | xargs -I{} sudo virsh vol-delete {} || true"
            ]
        }
    ],
    "variables": {
        "box_type": "__OVERIDE_BY_USER__",
        "box_os_version": "__OVERIDE_BY_USER__",
        "box_version": "__OVERIDE_BY_USER__",
        "base_box_name": "__OVERIDE_BY_USER__",
        "box_name": "{{user `name`}}-{{user `box_type`}}",
        "python_path": "__OVERIDE_BY_USER__",
        "source_path": "{{user `artifactory_download_url`}}/{{user `base_box_name`}}"
    }
}