# =============================================================================
# VM Image Builder — Configuration
# Copy to config.env, fill in real values. DO NOT commit config.env.
# =============================================================================

# --- JFrog Artifactory ---
ARTIFACTORY_URL=https://artifactory.example.com/artifactory
ARTIFACTORY_HOST=artifactory.example.com

# Artifactory credentials (set via CI/CD secrets, never hardcode)
ARTIFACTORY_API_KEY=your_api_key_here
ARTIFACTORY_ACCESS_TOKEN=your_access_token_here

# Vagrant boxes repository name
ARTIFACTORY_VAGRANT_REPO=vagrant-boxes-local
ARTIFACTORY_REPO_NAME=your-artifact-repo-name

# --- DNS ---
DNS_SERVERS="10.0.0.1 10.0.0.2"
DNS_SEARCH_DOMAINS="corp.example.com example.com"

# --- NFS ---
NFS_SERVER=nfs.example.com
NFS_DATA_SERVER=nfs-data.example.com

# --- SSH authorized keys ---
# Path to a file with additional public keys to inject into root/.ssh/authorized_keys
# Example: SSH_AUTHORIZED_KEYS_FILE=~/.ssh/id_rsa.pub
SSH_AUTHORIZED_KEYS_FILE=

# --- Build environment Docker image ---
PACKER_IMAGE=artifactory.example.com/devops-docker-local/packer-vagrant:builder

# --- JFrog CLI ---
JFROG_CLI_VER=jfrog_1.42.3

# --- Debug (optional) ---
# PACKER_LOG=1
# PACKER_DEBUG=1
# PACKER_DEV_ENV=1   # skips box creation step (-except=create-box)

# --- S3 (set STORAGE=s3 or STORAGE=both to enable) ---
S3_BUCKET=
S3_PREFIX=vagrant
# S3_ENDPOINT=https://s3.example.com   # for MinIO / non-AWS S3
# AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=